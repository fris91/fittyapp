{
  "info": {
    "name": "Fitty Local API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{gatewayUrl}}/api/v1/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"lucas@example.com\",\n  \"password\": \"Password123!\",\n  \"displayName\": \"Lucas\"\n}"
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{gatewayUrl}}/api/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"lucas@example.com\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "Create Health Snapshot",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{gatewayUrl}}/api/v1/health-data",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"weightKg\": 74.2,\n  \"heightCm\": 178,\n  \"heartRateBpm\": 72,\n  \"sleepHours\": 7.5,\n  \"steps\": 8400,\n  \"notes\": \"Good energy today\"\n}"
        }
      }
    }
  ],
  "variable": [
    { "key": "gatewayUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" }
  ]
}
